
@using DTOs.Book
@inject BlazorApp.Services.IBookService BookService

<div class="mt-3">
    <button class="btn btn-primary" @onclick="OnReserveClicked" disabled="@isReserving">
        @(isReserving ? "Reserving…" : "Reserve")
    </button>
</div>

@if (reservation != null)
{
    <div class="alert alert-success mt-3">
        <strong>Reserved!</strong><br />
        ISBN: @reservation.Isbn<br />
        Queue position: @reservation.QueuePosition<br />
        Expires: @reservation.ExpiresAt?.ToLocalTime().ToString("g")
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    [Parameter]
    public required string ISBN { get; set; }
    public EventCallback OnReservedSuccess { get; set; }
    private bool isReserving = false;
    private string? errorMessage;
    private ReservationDTO? reservation;
    private BookDTO? book;

    protected override async Task OnInitializedAsync()
    {
        await LoadBook();
    }

    private async Task LoadBook()
    {
        try
        {
            book = await BookService.GetBookAsync(ISBN);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load book: {ex.Message}";
        }
    }

    private async Task OnReserveClicked()
    {
        errorMessage = null;
        reservation = null;
        isReserving = true;

        try
        {
            if (book == null)
            {
                errorMessage = "Book not found.";
                return;
            }

            reservation = await BookService.ReserveBookAsync(book.BookId);
            if (OnReservedSuccess.HasDelegate)
            {
                await OnReservedSuccess.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isReserving = false;
        }
    }
}


